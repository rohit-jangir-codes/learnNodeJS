<!DOCTYPE html>
<html lang="en">
<head><%- include('partials/head') %></head>
<body class="bg-gray-50 min-h-screen flex flex-col">
  <%- include('partials/navbar') %>
  <main class="flex-grow flex items-center justify-center px-4 py-12">
    <div class="bg-white w-full max-w-lg rounded-2xl shadow-lg p-8">
      <h2 class="text-2xl font-bold text-gray-800 mb-2 text-center">List Your Home 🏡</h2>
      <p class="text-gray-500 text-center mb-6">Fill in the details below</p>
      <div id="auth-warning" class="hidden bg-yellow-50 border border-yellow-200 text-yellow-700 text-sm rounded-lg px-4 py-3 mb-4">⚠️ You must be <a href="/login" class="underline font-medium">logged in</a> to add a home.</div>
      <div id="error-msg"   class="hidden bg-red-50 border border-red-200 text-red-600 text-sm rounded-lg px-4 py-3 mb-4"></div>
      <div id="success-msg" class="hidden bg-green-50 border border-green-200 text-green-600 text-sm rounded-lg px-4 py-3 mb-4"></div>
      <form id="add-home-form" class="space-y-4">
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1">House Name *</label>
          <input type="text" id="house_name" required placeholder="e.g. Sunset Villa" class="w-full border border-gray-300 rounded-lg px-4 py-2.5 text-gray-800 focus:outline-none focus:ring-2 focus:ring-rose-400 transition" />
        </div>
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1">Location *</label>
          <input type="text" id="location" required placeholder="e.g. Goa, India" class="w-full border border-gray-300 rounded-lg px-4 py-2.5 text-gray-800 focus:outline-none focus:ring-2 focus:ring-rose-400 transition" />
        </div>
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1">Price per Night (₹) *</label>
          <input type="number" id="price_per_night" required min="1" placeholder="e.g. 3500" class="w-full border border-gray-300 rounded-lg px-4 py-2.5 text-gray-800 focus:outline-none focus:ring-2 focus:ring-rose-400 transition" />
        </div>
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1">Rating (0–5)</label>
          <input type="number" id="rating" min="0" max="5" step="0.1" placeholder="e.g. 4.5" class="w-full border border-gray-300 rounded-lg px-4 py-2.5 text-gray-800 focus:outline-none focus:ring-2 focus:ring-rose-400 transition" />
        </div>
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1">Photo URL</label>
          <input type="url" id="photo_url" placeholder="https://example.com/photo.jpg" class="w-full border border-gray-300 rounded-lg px-4 py-2.5 text-gray-800 focus:outline-none focus:ring-2 focus:ring-rose-400 transition" />
        </div>
        <button type="submit" id="submit-btn" class="w-full bg-rose-500 text-white py-3 rounded-lg font-semibold hover:bg-rose-600 transition">Add Home</button>
      </form>
    </div>
  </main>
  <script>
    const token = localStorage.getItem('token');
    if (!token) { document.getElementById('auth-warning').classList.remove('hidden'); document.getElementById('add-home-form').classList.add('opacity-50', 'pointer-events-none'); }
    document.getElementById('add-home-form').addEventListener('submit', async (e) => {
      e.preventDefault();
      if (!token) return;
      const btn = document.getElementById('submit-btn');
      const errorMsg = document.getElementById('error-msg');
      const successMsg = document.getElementById('success-msg');
      errorMsg.classList.add('hidden'); successMsg.classList.add('hidden');
      btn.textContent = 'Adding...'; btn.disabled = true;
      try {
        const res  = await fetch('/api/homes', { method: 'POST', headers: { 'Content-Type': 'application/json', 'Authorization': 'Bearer ' + token }, body: JSON.stringify({ house_name: document.getElementById('house_name').value, location: document.getElementById('location').value, price_per_night: parseFloat(document.getElementById('price_per_night').value), rating: parseFloat(document.getElementById('rating').value) || 0, photo_url: document.getElementById('photo_url').value || null }) });
        const data = await res.json();
        if (!data.success) { errorMsg.textContent = data.error || 'Failed to add home'; errorMsg.classList.remove('hidden'); btn.textContent = 'Add Home'; btn.disabled = false; return; }
        successMsg.textContent = '✅ Home added successfully! Redirecting...';
        successMsg.classList.remove('hidden');
        setTimeout(() => window.location.href = '/', 1200);
      } catch (err) { errorMsg.textContent = 'Something went wrong.'; errorMsg.classList.remove('hidden'); btn.textContent = 'Add Home'; btn.disabled = false; }
    });
  </script>
</body>
</html>